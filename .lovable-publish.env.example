# Copy this file to .lovable-publish.env and set exactly one target.

# Option 1: Lovable project root
LOVABLE_PROJECT_ROOT="/absolute/path/to/lovable-project"

# Option 2: Lovable public directory
# LOVABLE_PUBLIC_ROOT="/absolute/path/to/lovable-project/public"

# Option 3: Final publish directory
# LOVABLE_TARGET_DIR="/absolute/path/to/lovable-project/public/cli/registack-agent-detector"
